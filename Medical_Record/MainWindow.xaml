<Window x:Class="Medical_Record.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Medical_Record" Height="900" Width="900">
	<Grid>
		<!-- Menu Lateral -->
		<DockPanel LastChildFill="False" Width="200" Background="#F5F5F5" DockPanel.Dock="Left" HorizontalAlignment="Left" VerticalAlignment="Top">
			<StackPanel>
				<TextBlock Text="Medical_Record.app" FontSize="20" FontWeight="Bold" Foreground="Purple" Margin="10" />
				<Button Content="Dashboard" Margin="5" Padding="5"/>
				<Button Content="Agenda" Margin="5" Padding="5"/>
				<Button Content="Pacientes" Margin="5" Padding="5" Background="Purple" Foreground="White"/>
				<Button Content="Finanças" Margin="5" Padding="5"/>
				<Button Content="Educação" Margin="5" Padding="5"/>
				<Button Content="Suporte" Margin="5" Padding="5"/>
				<Button Content="Configurações" Margin="5" Padding="5"/>
				<Button Content="Sair" Margin="5" Padding="5" Foreground="Red"/>
			</StackPanel>
		</DockPanel>

		<!-- Conteúdo Principal -->
		<StackPanel Margin="210,10,10,10">
			<TextBlock Text="Pacientes" FontSize="18" FontWeight="Bold" />
			<Button Content="Adicionar Paciente" Background="Purple" Foreground="White" HorizontalAlignment="Right" Padding="5" Margin="5"/>

			<!-- ListView to Display Pacientes -->
			<ListView ItemsSource="{Binding Pacientes}">
				<ListView.View>
					<GridView>
						<GridViewColumn Header="Nome" DisplayMemberBinding="{Binding Nome}" Width="200"/>
						<GridViewColumn Header="Email" DisplayMemberBinding="{Binding Email}" Width="200"/>
						<GridViewColumn Header="Idade" DisplayMemberBinding="{Binding Idade}" Width="100"/>
						<GridViewColumn Header="Telefone" DisplayMemberBinding="{Binding Telefone}" Width="150"/>
						<GridViewColumn Header="Consultas" DisplayMemberBinding="{Binding Consultas}" Width="100"/>
					</GridView>
				</ListView.View>
			</ListView>
		</StackPanel>
	</Grid>
</Window>
